{
  "info": {
    "name": "Dungeon Gate Economy",
    "description": "API collection for Phases 1–3. Run in order: Register → Login → authenticated endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000",
      "type": "string"
    },
    {
      "key": "access_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "refresh_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "player_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "intent_id",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health & Infra",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/health",
              "host": ["{{base_url}}"],
              "path": ["health"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Body has status ok', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.status).to.eql('ok');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Readiness Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/ready",
              "host": ["{{base_url}}"],
              "path": ["ready"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('DB and Redis ok', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.database).to.eql('ok');",
                  "  pm.expect(body.redis).to.eql('ok');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testplayer\",\n  \"email\": \"test@example.com\",\n  \"password\": \"SecurePass123!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": ["{{base_url}}"],
              "path": ["auth", "register"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const status = pm.response.code;",
                  "if (status === 201) {",
                  "  pm.test('Registration successful', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('id');",
                  "    pm.collectionVariables.set('player_id', body.id);",
                  "  });",
                  "} else if (status === 409 || status === 400) {",
                  "  pm.test('Already registered (expected on re-run)', () => {",
                  "    pm.expect(status).to.be.oneOf([400, 409]);",
                  "  });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Register — Duplicate (expect fail)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testplayer\",\n  \"email\": \"test@example.com\",\n  \"password\": \"SecurePass123!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": ["{{base_url}}"],
              "path": ["auth", "register"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Duplicate rejected', () => {",
                  "  pm.expect(pm.response.code).to.be.oneOf([400, 409]);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"SecurePass123!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Login successful', () => {",
                  "  pm.response.to.have.status(200);",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('access_token');",
                  "  pm.expect(body).to.have.property('refresh_token');",
                  "  pm.collectionVariables.set('access_token', body.access_token);",
                  "  pm.collectionVariables.set('refresh_token', body.refresh_token);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Login — Wrong Password (expect fail)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"WrongPassword!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Login rejected', () => {",
                  "  pm.expect(pm.response.code).to.be.oneOf([400, 401]);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/refresh",
              "host": ["{{base_url}}"],
              "path": ["auth", "refresh"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Refresh successful', () => {",
                  "  pm.response.to.have.status(200);",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('access_token');",
                  "  pm.collectionVariables.set('access_token', body.access_token);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Player",
      "item": [
        {
          "name": "My Profile",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/players/me",
              "host": ["{{base_url}}"],
              "path": ["players", "me"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Profile returned', () => {",
                  "  pm.response.to.have.status(200);",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('username');",
                  "  pm.expect(body).to.have.property('balance_micro');",
                  "  pm.expect(body.balance_micro).to.be.a('number');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "My Profile — No Auth (expect fail)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/players/me",
              "host": ["{{base_url}}"],
              "path": ["players", "me"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Rejected without token', () => {",
                  "  pm.expect(pm.response.code).to.be.oneOf([401, 403]);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "My Ledger",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/players/me/ledger?limit=10&offset=0",
              "host": ["{{base_url}}"],
              "path": ["players", "me", "ledger"],
              "query": [
                { "key": "limit", "value": "10" },
                { "key": "offset", "value": "0" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Ledger returned', () => {",
                  "  pm.response.to.have.status(200);",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.be.an('array');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Simulation",
      "item": [
        {
          "name": "Simulation Status",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/simulation/status",
              "host": ["{{base_url}}"],
              "path": ["simulation", "status"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status returned', () => {",
                  "  pm.response.to.have.status(200);",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('current_tick');",
                  "  pm.expect(body).to.have.property('is_running');",
                  "  pm.expect(body).to.have.property('treasury_balance');",
                  "  pm.expect(body.current_tick).to.be.a('number');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Intents",
      "item": [
        {
          "name": "Submit Intent — DISCOVER_GATE",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"intent_type\": \"DISCOVER_GATE\",\n  \"payload\": {\"min_rank\": \"C\"}\n}"
            },
            "url": {
              "raw": "{{base_url}}/intents",
              "host": ["{{base_url}}"],
              "path": ["intents"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Intent created', () => {",
                  "  pm.response.to.have.status(201);",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.status).to.eql('QUEUED');",
                  "  pm.expect(body.intent_type).to.eql('DISCOVER_GATE');",
                  "  pm.expect(body).to.have.property('id');",
                  "  pm.collectionVariables.set('intent_id', body.id);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Submit Intent — PLACE_ORDER",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"intent_type\": \"PLACE_ORDER\",\n  \"payload\": {\n    \"asset_type\": \"GATE_SHARE\",\n    \"asset_id\": \"00000000-0000-0000-0000-000000000000\",\n    \"side\": \"BUY\",\n    \"quantity\": 10,\n    \"price_limit\": 5000000\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}/intents",
              "host": ["{{base_url}}"],
              "path": ["intents"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Intent created', () => {",
                  "  pm.response.to.have.status(201);",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.status).to.eql('QUEUED');",
                  "  pm.expect(body.intent_type).to.eql('PLACE_ORDER');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Submit Intent — CREATE_GUILD",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"intent_type\": \"CREATE_GUILD\",\n  \"payload\": {\n    \"name\": \"TestGuild\",\n    \"public_float_pct\": 0.30,\n    \"dividend_policy\": \"AUTO_FIXED_PCT\",\n    \"auto_dividend_pct\": 0.05\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}/intents",
              "host": ["{{base_url}}"],
              "path": ["intents"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Intent created', () => {",
                  "  pm.response.to.have.status(201);",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.status).to.eql('QUEUED');",
                  "  pm.expect(body.intent_type).to.eql('CREATE_GUILD');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Submit Intent — No Auth (expect fail)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"intent_type\": \"DISCOVER_GATE\",\n  \"payload\": {\"min_rank\": \"E\"}\n}"
            },
            "url": {
              "raw": "{{base_url}}/intents",
              "host": ["{{base_url}}"],
              "path": ["intents"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Rejected without auth', () => {",
                  "  pm.expect(pm.response.code).to.be.oneOf([401, 403]);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Submit Intent — Invalid Type (expect fail)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"intent_type\": \"INVALID_TYPE\",\n  \"payload\": {}\n}"
            },
            "url": {
              "raw": "{{base_url}}/intents",
              "host": ["{{base_url}}"],
              "path": ["intents"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Invalid type rejected', () => {",
                  "  pm.response.to.have.status(422);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Simulation Status (after ticks)",
      "item": [
        {
          "name": "Check Ticks Advancing",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/simulation/status",
              "host": ["{{base_url}}"],
              "path": ["simulation", "status"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Ticks are advancing', () => {",
                  "  pm.response.to.have.status(200);",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.current_tick).to.be.above(0);",
                  "  pm.expect(body.is_running).to.eql(true);",
                  "});",
                  "",
                  "pm.test('Treasury balance is positive', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.treasury_balance).to.be.above(0);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    }
  ]
}
